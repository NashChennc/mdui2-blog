
<!-- 1. Hero Banner 区域 -->
<div class="hero-banner">
    <%
        // 获取本地 banner 目录下的所有文件名列表
        var bannerImageList = get_banner_list();
        var fallbackImage = "";
        
        // 如果有图片，随机选一张作为首页全屏背景
        if (bannerImageList && bannerImageList.length > 0) {
            var randomIndex = Math.floor(Math.random() * bannerImageList.length);
            fallbackImage = url_for('image/banner/' + bannerImageList[randomIndex]);
        } else {
            // 兜底图片 (如果文件夹为空)
            fallbackImage = theme.banner && theme.banner.image
        }
    %>
    <div class="hero-bg" style='--banner-bg-image: url("<%- mdblog_safe_css_url((theme.banner && theme.banner.image) || config.head_bgpaper || fallbackImage) %>");'></div>
    <div class="hero-mask"></div>

    <div class="hero-content hero-content--index">
        <h1 class="hero-content__title">
            <%- partial('partial/banner-hero-titles', { variant: 'index', role: 'title' }) %>
        </h1>
        <div class="hero-content__subtitle hero-content__subtitle--spaced">
            <%- partial('partial/banner-hero-titles', { variant: 'index', role: 'subtitle' }) %>
        </div>
    </div>
    <div class="hero-scroll-hint" aria-hidden="true">
        <mdui-icon name="expand_more" class="hero-scroll-hint__icon"></mdui-icon>
    </div>
</div>

<!-- 2. 主要内容区域 -->
<div class="page-shell app-container page-shell--pad-index">
    <div class="page-grid page-grid--single">
        <main class="page-main">
            <%
                var indexTitle = '';
                if (theme.index_page && theme.index_page.title) {
                    indexTitle = String(theme.index_page.title).trim();
                }
                if (!indexTitle && config.title) {
                    indexTitle = String(config.title).trim();
                }
                var indexLede = '';
                if (theme.index_page && theme.index_page.lede) {
                    indexLede = String(theme.index_page.lede).trim();
                }
                if (!indexLede) {
                    var _indexLedeI18n = __('index_page_default_lede');
                    if (_indexLedeI18n && _indexLedeI18n !== 'index_page_default_lede') {
                        indexLede = String(_indexLedeI18n).trim();
                    }
                }
            %>
            <% if (indexTitle) { %>
            <header class="notes-header notes-header--index">
                <h2 class="notes-title"><%= indexTitle %></h2>
                <% if (indexLede) { %>
                <p class="notes-subtitle"><%- indexLede %></p>
                <% } %>
            </header>
            <% } %>
            <%- partial('partial/index-taxonomy') %>
            <div class="notes-grid notes-grid--index">
                <% page.posts.each(function(post, i){ %>
                    <div class="notes-grid__cell scroll-reveal <%= (i === 0 && page.current === 1) ? 'featured-post' : '' %>">
                        <%- partial('partial/category-note-card', { post: post, i: i, pageCurrent: page.current }) %>
                    </div>
                <% }) %>
            </div>

            <% if (page.total > 1){ %>
                <%- partial('partial/paginator', { paginatorWrapClass: 'scroll-reveal' }) %>
            <% } %>
        </main>
    </div>
</div>
<div id="page-bottom" aria-hidden="true"></div>
