<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>" class="mdui-theme-auto">
<head>
  <meta charset="UTF-8">
  <script>
    (function () {
      var KEY = 'mdblog-theme';
      var el = document.documentElement;
      try {
        var t = localStorage.getItem(KEY);
        el.classList.remove('mdui-theme-auto', 'mdui-theme-light', 'mdui-theme-dark');
        if (t === 'light' || t === 'dark') {
          el.classList.add('mdui-theme-' + t);
        } else {
          el.classList.add('mdui-theme-auto');
        }
      } catch (err) {
        el.classList.remove('mdui-theme-light', 'mdui-theme-dark');
        if (!el.classList.contains('mdui-theme-auto')) el.classList.add('mdui-theme-auto');
      }
    })();
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title><%= page.title ? page.title + ' - ' : '' %><%= config.title %></title>

  <!-- MDUI 2 核心样式（先于图标与站点覆盖） -->
  <link rel="stylesheet" href="<%- url_for('mdui2/mdui.css') %>">
  <link rel="stylesheet" href="<%- url_for('mdui2/outlined.css') %>">
  <!-- 与 MDUI mdui-icon 使用的 Material Icons* 家族名对齐，否则仅 outlined.css 时图标不显示 -->
  <link rel="stylesheet" href="<%- url_for('mdui2/mdui-material-font-aliases.css') %>">

  <!-- Font Awesome 6 for brand icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <% if (!theme.katex || theme.katex.enable !== false) { %>
  <!-- KaTeX CSS -->
  <link rel="stylesheet" href="<%- url_for('katex/katex.min.css') %>">
  <% } %>

  <!-- 站点样式：并行加载各模块，避免单入口 custom.css 内 @import 串行阻塞 FCP -->
  <% const mdblogCss = [
    'css/tokens.css',
    'css/global-layout.css',
    'css/topbar.css',
    'css/hero.css',
    'css/motion-scroll-reveal.css',
    'css/lists-cards.css',
    'css/categories-postinfo.css',
    'css/footer.css',
    'css/banner-page.css',
    'css/sidebar-footer.css',
    'css/article-prose.css',
    'css/index-taxonomy.css',
    'css/site-search.css'
  ]; %>
  <% mdblogCss.forEach(function (href) { %>
  <link rel="stylesheet" href="<%- url_for(href) %>">
  <% }); %>
  <link rel="stylesheet" href="<%- url_for('css/custom.css') %>">

  <meta name="theme-color" content="<%= theme.theme_color || '#6750A4' %>">
</head>
<body id="top">
  
  <!-- Header/AppBar -->
  <%- partial('partial/topbar') %>
  <%- partial('partial/site-search-dock') %>

  <!-- Main Content (Layout control moved to individual views) -->
  <div id="main-content">
    <%- body %>
  </div>
  <!-- Footer -->
  <%- partial('partial/footer') %>

  <!-- Scripts -->
  <script src="<%- url_for('mdui2/mdui.global.js') %>"></script>
  <script src="<%- url_for('/js/note-card-layout.js') %>" defer></script>
  <script src="<%- url_for('/js/theme-toggle.js') %>" defer></script>
  <script src="<%- url_for('/js/site-search.js') %>" defer></script>
  <script src="<%- url_for('/js/motion-scroll-reveal.js') %>" defer></script>
  <script src="<%- url_for('/js/index-taxonomy-tags.js') %>" defer></script>
  <% if (!theme.katex || theme.katex.enable !== false) { %>
  <script src="<%- url_for('katex/katex.min.js') %>"></script>
  <script src="<%- url_for('katex/contrib/auto-render.min.js') %>"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      renderMathInElement(document.body, {
        delimiters: [
          {left: '$$', right: '$$', display: true},
          {left: '$', right: '$', display: false},
          {left: '\\(', right: '\\)', display: false},
          {left: '\\[', right: '\\]', display: true}
        ],
        ignoredTags: ["script", "noscript", "style", "textarea", "pre", "code"]
      });
    });
  </script>
  <% } %>
  <% if (config.mermaid && config.mermaid.enable) { %>
  <script src="<%- url_for('mermaid/mermaid.min.js') %>"></script>
  <script>
    (function () {
      if (!window.mermaid) return;
      var m = <%- JSON.stringify(config.mermaid) %>;
      var opts = Object.assign({}, m);
      delete opts.enable;
      delete opts.version;
      var nested = opts.options;
      delete opts.options;
      if (nested && typeof nested === 'object') Object.assign(opts, nested);
      mermaid.initialize(opts);
    })();
  </script>
  <% } %>
</body>
</html>
