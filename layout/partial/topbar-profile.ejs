<%
  var sidebarConfig = theme.sidebar_config || {};
  var profileAvatar = mdblog_safe_url(sidebarConfig.avatar || theme.avatar);
%>
<div class="topbar-profile-cluster">
  <mdui-button-icon
    variant="standard"
    class="topbar-profile-trigger-btn"
    href="<%- url_for('/about') %>"
    aria-label="<%= __('about') %>"
    <% if (typeof page !== 'undefined' && page.path && /^about(\/|$)/.test(page.path)) { %>aria-current="page"<% } %>
  >
    <% if (profileAvatar) { %>
      <img src="<%= profileAvatar %>" class="topbar-profile-trigger__avatar" alt="" width="40" height="40" decoding="async">
    <% } else { %>
      <mdui-icon name="person" class="topbar-profile-trigger__avatar-icon"></mdui-icon>
    <% } %>
  </mdui-button-icon>

  <% if (theme.social) { %>
    <nav class="topbar-profile-social-bar" aria-label="<%= __('topbar_social_links') %>">
      <% for (var k in theme.social) { %>
        <%
          var item = theme.social[k] || {};
          var itemHref = mdblog_safe_url(item.link);
          var itemLabel = item.text || item.link || k;
          var itemIconClass = mdblog_class_list(item.icon);
          var itemColorClass = mdblog_class_list(item.color);
        %>
        <% if (itemHref) { %>
        <mdui-button-icon
          class="topbar-profile-social-bar__btn"
          variant="standard"
          href="<%= url_for(itemHref) %>"
          target="_blank"
          rel="noopener noreferrer"
          title="<%= itemLabel %>"
          aria-label="<%= itemLabel %>"
        >
          <i class="<%= itemIconClass %> <%= itemColorClass %> topbar-profile-social-bar__icon" aria-hidden="true"></i>
        </mdui-button-icon>
        <% } %>
      <% } %>
    </nav>
  <% } %>
</div>
