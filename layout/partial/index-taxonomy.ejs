<%
  var taxonomyShowCategories = taxonomyShowCategories === false ? false : true;
  var taxonomyShowTags = taxonomyShowTags === false ? false : true;

  /* 标签：仅统计当前页 page.posts 内出现的标签及本页篇数 */
  var pageTagList = [];
  if (typeof page !== 'undefined' && page.posts && page.posts.length) {
    var _tagMap = {};
    page.posts.each(function (post) {
      if (post.tags && post.tags.length) {
        post.tags.each(function (tag) {
          var n = tag.name;
          if (!_tagMap[n]) {
            _tagMap[n] = { name: tag.name, path: tag.path, count: 0 };
          }
          _tagMap[n].count += 1;
        });
      }
    });
    for (var _k in _tagMap) {
      if (Object.prototype.hasOwnProperty.call(_tagMap, _k)) {
        pageTagList.push(_tagMap[_k]);
      }
    }
    pageTagList.sort(function (a, b) {
      if (b.count !== a.count) return b.count - a.count;
      return String(a.name).localeCompare(String(b.name), undefined, { sensitivity: 'base' });
    });
  }

  var hasCatBlock = taxonomyShowCategories && site.categories.length;
  var hasTagBlock = taxonomyShowTags && pageTagList.length;

  /* 标签渐进披露：初屏条数（0 = 不折叠，来自 theme.index_taxonomy.tags_visible_initial） */
  var _tagInitial = theme.index_taxonomy && typeof theme.index_taxonomy.tags_visible_initial === 'number'
    ? theme.index_taxonomy.tags_visible_initial
    : 8;
  var tagInitialLimit = _tagInitial < 0 ? 8 : _tagInitial;
  var tagOverflowActive = tagInitialLimit > 0 && pageTagList.length > tagInitialLimit;
  var pageTagListTop = tagOverflowActive ? pageTagList.slice(0, tagInitialLimit) : pageTagList;
  var pageTagListRest = tagOverflowActive ? pageTagList.slice(tagInitialLimit) : [];
%>
<% if (hasCatBlock || hasTagBlock) { %>
<section class="index-taxonomy" aria-label="<%= __('index_taxonomy_nav') %>">
  <% if (hasCatBlock) { %>
  <div class="index-taxonomy__block" aria-label="<%= __('categories') %>">
    <div class="index-taxonomy__chips" role="list">
      <% site.categories.sort('length').sort('-name').each(function (item) { %>
        <% if (item.posts.length) { %>
      <a
        role="listitem"
        class="index-taxonomy__chip"
        href="<%- url_for('categories/' + item.name) %>"
        <% if (typeof page !== 'undefined' && is_category() && page.category === item.name) { %>aria-current="page"<% } %>
      ><%= item.name %> · <%= item.posts.length %></a>
        <% } %>
      <% }); %>
    </div>
  </div>
  <% } %>
  <% if (hasTagBlock) { %>
  <div class="index-taxonomy__block index-taxonomy__block--tags" aria-label="<%= __('tags') %>">
    <div class="index-taxonomy__tags-panel">
      <div class="index-taxonomy__tags-flow">
        <div class="index-taxonomy__chips index-taxonomy__chips--in-flow" role="list">
          <% pageTagListTop.forEach(function (item) { %>
      <a
        role="listitem"
        class="index-taxonomy__chip"
        href="<%- url_for(item.path) %>"
        <% if (typeof page !== 'undefined' && is_tag() && page.tag === item.name) { %>aria-current="page"<% } %>
      ><%= item.name %> · <%= item.count %></a>
          <% }); %>
        </div>
        <% if (tagOverflowActive) { %>
        <details class="index-taxonomy__tags-details">
          <summary class="index-taxonomy__tags-summary">
            <span class="index-taxonomy__tags-summary-label index-taxonomy__tags-summary-label--collapsed"><%= __('tags_show_more', pageTagListRest.length) %></span>
            <span class="index-taxonomy__tags-summary-label index-taxonomy__tags-summary-label--expanded"><%= __('tags_show_less') %></span>
          </summary>
          <div class="index-taxonomy__tags-overflow-sleeve">
            <div class="index-taxonomy__chips index-taxonomy__chips--overflow" role="list">
              <% pageTagListRest.forEach(function (item) { %>
      <a
        role="listitem"
        class="index-taxonomy__chip"
        href="<%- url_for(item.path) %>"
        <% if (typeof page !== 'undefined' && is_tag() && page.tag === item.name) { %>aria-current="page"<% } %>
      ><%= item.name %> · <%= item.count %></a>
              <% }); %>
            </div>
            <button type="button" class="index-taxonomy__tags-less"><%= __('tags_show_less') %></button>
          </div>
        </details>
        <% } %>
      </div>
    </div>
  </div>
  <% } %>
</section>
<% } %>
