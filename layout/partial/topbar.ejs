<mdui-top-app-bar class="app-top-bar">
  <% if (site.categories.length) { %>
    <div class="topbar-home">
      <mdui-button
        variant="text"
        href="<%- url_for('/') %>"
        class="topbar-nav-btn topbar-home__btn<%= is_home() ? ' topbar-nav-btn--active' : '' %>"
        <% if (is_home()) { %>aria-current="page"<% } %>
      ><%= __('home') %></mdui-button>
    </div>
    <div class="topbar-spacer" aria-hidden="true"></div>
    <nav class="topbar-nav mdui-prose mdui-prose--inline-nav" aria-label="<%= __('categories') %>">
      <% site.categories.sort('length').sort('-name').each(item => { %>
        <% if (item.posts.length) { %>
      <a
        href="<%- url_for('categories/' + item.name) %>"
        <% if (is_category() && page.category === item.name) { %>aria-current="page"<% } %>
      ><%= item.name %> | <%= item.posts.length %></a>
        <% } %>
      <% }); %>
    </nav>
  <% } else { %>
    <mdui-top-app-bar-title><%= config.title %></mdui-top-app-bar-title>
    <div class="topbar-spacer" aria-hidden="true"></div>
  <% } %>
  <div class="topbar-end">
    <mdui-button-icon
      id="site-search-toggle"
      variant="standard"
      icon="search"
      class="topbar-search-toggle"
      aria-label="<%= __('search') %>"
      aria-expanded="false"
      aria-haspopup="dialog"
      aria-controls="search-palette"
      aria-keyshortcuts="Control+K Meta+K"
    ></mdui-button-icon>
    <mdui-button-icon
      id="theme-toggle"
      variant="standard"
      icon="dark_mode"
      class="topbar-theme-toggle"
      data-label-dark="<%= __('theme_toggle_to_dark') %>"
      data-label-light="<%= __('theme_toggle_to_light') %>"
      data-label-follow="<%= __('theme_toggle_follow_system') %>"
      aria-label="<%= __('theme_toggle_to_dark') %>"
    ></mdui-button-icon>
    <%- partial('partial/topbar-profile') %>
  </div>
</mdui-top-app-bar>
